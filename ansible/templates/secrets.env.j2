POSTGRES_PASSWORD={{ pg_password }}
JWT_SECRET={{ jwt_secret }}
DATABASE_URL_PROD=postgresql://{{ pg_user }}:{{ pg_password }}@localhost:5432/{{ pg_db_prod }}
DATABASE_URL_TEST=postgresql://{{ pg_user }}:{{ pg_password }}@localhost:5432/{{ pg_db_test }}
{% if s3_access_key is defined %}
S3_ACCESS_KEY={{ s3_access_key }}
S3_SECRET_KEY={{ s3_secret_key }}
{% endif %}
