# =============================================================================
# Caddy reverse proxy — Wall & Shadow
# =============================================================================
# Managed by Ansible. Do not edit directly on the VPS.
# Source: ansible/templates/Caddyfile.j2
# =============================================================================

{
    email admin@wallandshadow.com
}

# Drop scanner traffic on :80 with unknown Host headers. Named-site blocks
# below win on Host match, so this only catches IP/unknown-host requests.
# ACME HTTP-01 challenges target the named hostname, so they hit the named
# site (not this block) and continue to work. :443 needs no catch-all —
# scanners hitting the IP fail at TLS handshake (no cert for unknown SNI).
:80 {
    respond 444
}

{% set csp_policy %}
default-src 'self';
script-src 'self';
style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;
font-src 'self' https://fonts.gstatic.com data:;
img-src 'self' data: blob: {{ s3_endpoint }} https://robohash.org;
connect-src 'self' {{ oidc_issuer }};
frame-ancestors 'none';
base-uri 'self';
form-action 'self';
object-src 'none'
{% endset %}
{% set csp_policy_flat = csp_policy | replace('\n', ' ') | trim %}

(security-headers) {
    Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    X-Frame-Options "DENY"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    Content-Security-Policy "{{ csp_policy_flat }}"
    Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), accelerometer=(), gyroscope=()"
}

{{ domain_prod }} {
    encode zstd gzip

    log {
        output file /var/log/caddy/access.log {
            roll_size 50mb
            roll_keep 8
            roll_keep_for 720h
        }
        format json
    }

    handle_path /stats* {
        basic_auth {
            {{ stats_basic_auth_user }} {{ stats_basic_auth_hash }}
        }
        root * /var/www/stats
        file_server
    }

    handle {
        reverse_proxy localhost:{{ app_port_prod }}
    }

    header {
        import security-headers
    }
}

{{ domain_test }} {
    encode zstd gzip

    reverse_proxy localhost:{{ app_port_test }}

    header {
        import security-headers
        X-Robots-Tag "noindex, nofollow"
    }
}
