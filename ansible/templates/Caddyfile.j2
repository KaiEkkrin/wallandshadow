# =============================================================================
# Caddy reverse proxy — Wall & Shadow
# =============================================================================
# Managed by Ansible. Do not edit directly on the VPS.
# Source: ansible/templates/Caddyfile.j2
# =============================================================================

{
    email admin@wallandshadow.com
}

{{ domain_prod }} {
    encode zstd gzip

    log {
        output file /var/log/caddy/access.log {
            roll_size 50mb
            roll_keep 8
            roll_keep_for 720h
        }
        format json
    }

    handle_path /stats* {
        basic_auth {
            {{ stats_basic_auth_user }} {{ stats_basic_auth_hash }}
        }
        root * /var/www/stats
        file_server
    }

    handle {
        reverse_proxy localhost:{{ app_port_prod }}
    }

    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

{{ domain_test }} {
    encode zstd gzip

    reverse_proxy localhost:{{ app_port_test }}

    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Robots-Tag "noindex, nofollow"
    }
}
