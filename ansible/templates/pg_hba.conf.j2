# =============================================================================
# PostgreSQL client authentication — Wall & Shadow
# =============================================================================
# Managed by Ansible. Do not edit directly on the VPS.
# Source: ansible/templates/pg_hba.conf.j2
#
# Local connections only. Application containers reach PostgreSQL via
# localhost (Docker host networking). No remote access.
# =============================================================================

# TYPE  DATABASE        USER            ADDRESS         METHOD

# Local socket connections (used by postgres superuser and pg_dump)
local   all             postgres                        peer
local   all             all                             peer

# IPv4 local connections (used by application containers via host networking)
host    all             all             127.0.0.1/32    scram-sha-256

# IPv6 local connections
host    all             all             ::1/128         scram-sha-256
