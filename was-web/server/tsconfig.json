{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@wallandshadow/shared": ["../packages/shared/src/index.ts"],
      "@wallandshadow/shared/*": ["../packages/shared/src/*"]
    }
  },
  "include": ["src", "drizzle.config.ts"]
}
