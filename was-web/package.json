{
  "name": "was-web",
  "version": "2.0.2",
  "private": true,
  "workspaces": [
    "packages/shared",
    "server"
  ],
  "type": "module",
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@popperjs/core": "^2.11.8",
    "blueimp-md5": "^2.19.0",
    "bootstrap": "^5.3.0",
    "chroma-js": "^3.2.0",
    "dayjs": "^1.8.36",
    "fluent-iterable": "^0.1.6",
    "oidc-client-ts": "^3.5.0",
    "react": "^19.0.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.0.0",
    "react-router-bootstrap": "^0.26.3",
    "react-router-dom": "^6.30.3",
    "react-use-measure": "^2.1.1",
    "rxjs": "^7.8.0",
    "three": "^0.183.0",
    "uuid": "^14.0.0"
  },
  "scripts": {
    "start": "vite --host",
    "dev:vite": "vite --host",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest --config ./unit/vitest.config.ts run",
    "test:unit": "vitest --config ./unit/vitest.config.ts",
    "test:server": "yarn workspace @wallandshadow/server test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui-host=0.0.0.0 --ui-port=8444",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report --host 0.0.0.0 e2e/test-results/html",
    "lint": "eslint src packages/shared/src"
  },
  "resolutions": {
    "tar": ">=7.5.11",
    "fast-xml-parser": ">=5.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^9.3.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/blueimp-md5": "^2.18.2",
    "@types/chroma-js": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-router-bootstrap": "^0.26.8",
    "@types/three": "^0.183.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@wallandshadow/shared": "*",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.2.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.3.2",
    "vitest": "^4.0.0"
  }
}
