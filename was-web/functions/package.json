{
  "name": "functions",
  "version": "1.4.4",
  "scripts": {
    "lint": "eslint --ext .ts src",
    "build": "tsc",
    "watch": "tsc -w",
    "serve": "yarn build && firebase emulators:start --only auth,firestore,functions",
    "shell": "yarn build && firebase functions:shell",
    "start": "yarn shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@firebase/app-types": "0.x",
    "dayjs": "^1.8.36",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0",
    "fluent-iterable": "^0.1.6",
    "rxjs": "^7.8.0",
    "three": "^0.182.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "^5.7.0"
  },
  "resolutions": {
    "eslint/**/minimatch": "3.1.5",
    "@eslint/config-array/minimatch": "3.1.5",
    "@eslint/eslintrc/minimatch": "3.1.5",
    "eslint-plugin-import/**/minimatch": "3.1.5",
    "minimatch": "9.0.7",
    "ajv": "6.14.0",
    "node-forge": "1.4.0",
    "protobufjs": "^7.5.5"
  },
  "private": true
}
