{
  "name": "Wall & Shadow Development (NVIDIA GPU)",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },

  "workspaceFolder": "/workspaces/wallandshadow",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/wallandshadow,type=bind,Z",

  // --device=nvidia.com/gpu=all uses Podman's CDI (Container Device Interface) interface.
  // Requires on host:
  //   1. nvidia-container-toolkit installed
  //   2. CDI configured: nvidia-ctk cdi generate --output=/etc/cdi/nvidia.yaml
  // --tmpfs=/tmp: workaround for crun >= 1.11 regression (podman#20754) that corrupts /tmp
  // permissions during devcontainer feature builds. See .devcontainer/X11_PERMISSION_RESEARCH.md.
  "runArgs": [
    "--shm-size=2g",
    "--userns=keep-id",
    "--tmpfs=/tmp:rw,exec,mode=1777",
    "--device=nvidia.com/gpu=all"
  ],

  "updateRemoteUserUID": false,

  "containerEnv": {
    "IS_LOCAL_DEV": "true",
    "FORCE_COLOR": "true",
    "GOOGLE_APPLICATION_CREDENTIALS": "/workspaces/wallandshadow/was-web/firebase-admin-credentials.json",
    "NVIDIA_VISIBLE_DEVICES": "all",
    "NVIDIA_DRIVER_CAPABILITIES": "all"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "dreamcatcher45.podmanager",
        "toba.vsfire",
        "dsznajder.es7-react-js-snippets",
        "vitest.vitest-explorer",
        "ms-playwright.playwright",
        "eamodio.gitlens",
        "christian-kohler.path-intellisense"
      ],
      "settings": {
        "editor.tabSize": 2,
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.tsdk": "was-web/node_modules/typescript/lib",
        "eslint.workingDirectories": ["was-web", "was-web/functions"],
        "files.exclude": {
          "**/.git": true,
          "**/.DS_Store": true,
          "**/node_modules": true,
          "**/.usercache": true
        },
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "forwardPorts": [3400, 4000, 5000, 5001, 7000, 8080, 9005, 9099, 9199, 9229, 9323],

  "portsAttributes": {
    "3400": {
      "label": "Firebase Hosting",
      "onAutoForward": "notify"
    },
    "4000": {
      "label": "Firebase Emulator UI",
      "onAutoForward": "openBrowser"
    },
    "5000": {
      "label": "React Dev Server",
      "onAutoForward": "openBrowser"
    },
    "5001": {
      "label": "Firebase Functions",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Firestore Emulator",
      "onAutoForward": "silent"
    },
    "9005": {
      "label": "Firestore Debug",
      "onAutoForward": "silent"
    },
    "9099": {
      "label": "Firebase Auth",
      "onAutoForward": "silent"
    },
    "9199": {
      "label": "Firebase Storage",
      "onAutoForward": "silent"
    },
    "9229": {
      "label": "Node Debug",
      "onAutoForward": "silent"
    },
    "9323": {
      "label": "Playwright Report",
      "onAutoForward": "notify"
    }
  },

  "postCreateCommand": "bash .devcontainer/scripts/post-create.sh",
  "postStartCommand": "git config --global --add safe.directory ${containerWorkspaceFolder} && bash .devcontainer/scripts/post-start.sh",

  "remoteUser": "node",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  }
}
