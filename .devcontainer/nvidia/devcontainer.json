{
  "name": "Wall & Shadow Development (NVIDIA GPU)",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },

  "workspaceFolder": "/workspaces/wallandshadow",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/wallandshadow,type=bind,Z",

  // --device=nvidia.com/gpu=all uses Podman's CDI (Container Device Interface) interface.
  // Requires on host:
  //   1. nvidia-container-toolkit installed
  //   2. CDI configured: nvidia-ctk cdi generate --output=/etc/cdi/nvidia.yaml
  // --tmpfs=/tmp: workaround for crun >= 1.11 regression (podman#20754) that corrupts /tmp
  // permissions during devcontainer feature builds. See .devcontainer/X11_PERMISSION_RESEARCH.md.
  "runArgs": [
    "--shm-size=2g",
    "--userns=keep-id",
    "--tmpfs=/tmp:rw,exec,mode=1777",
    "--device=nvidia.com/gpu=all",
    // Publish browser-facing ports explicitly — the devcontainer CLI does not honour
    // forwardPorts (github.com/devcontainers/cli/issues/22).
    "-p=3000:3000",
    "-p=5000:5000",
    "-p=9001:9001",
    "-p=9323:9323"
  ],

  "updateRemoteUserUID": false,

  "containerEnv": {
    "IS_LOCAL_DEV": "true",
    "FORCE_COLOR": "true",
    "EDITOR": "nvim",
    "VISUAL": "nvim",
    "NVIDIA_VISIBLE_DEVICES": "all",
    "NVIDIA_DRIVER_CAPABILITIES": "all",
    "PGDATA": "/workspaces/wallandshadow/.devcontainer/.pgdata",
    "DATABASE_URL": "postgresql://was:wasdev@localhost:5432/wallandshadow",
    "S3_ENDPOINT": "http://127.0.0.1:9000",
    "S3_BUCKET": "wallandshadow",
    "S3_ACCESS_KEY": "wasdev",
    "S3_SECRET_KEY": "wasdevpass"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "dreamcatcher45.podmanager",
        "dsznajder.es7-react-js-snippets",
        "vitest.vitest-explorer",
        "ms-playwright.playwright",
        "eamodio.gitlens",
        "christian-kohler.path-intellisense"
      ],
      "settings": {
        "editor.tabSize": 2,
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.tsdk": "was-web/node_modules/typescript/lib",
        "eslint.workingDirectories": ["was-web"],
        "files.exclude": {
          "**/.git": true,
          "**/.DS_Store": true,
          "**/node_modules": true,
          "**/.usercache": true
        },
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "forwardPorts": [3000, 5000, 9229, 9323, 5432, 9000, 9001],

  "portsAttributes": {
    "3000": {
      "label": "Hono API Server",
      "onAutoForward": "notify"
    },
    "5000": {
      "label": "React Dev Server",
      "onAutoForward": "openBrowser"
    },
    "9229": {
      "label": "Node Debug",
      "onAutoForward": "silent"
    },
    "9323": {
      "label": "Playwright Report",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    },
    "9000": {
      "label": "MinIO API",
      "onAutoForward": "silent"
    },
    "9001": {
      "label": "MinIO Console",
      "onAutoForward": "openBrowser"
    }
  },

  "postCreateCommand": "bash .devcontainer/scripts/post-create.sh",
  "postStartCommand": "git config --global --add safe.directory ${containerWorkspaceFolder} && bash .devcontainer/scripts/post-start.sh",

  "remoteUser": "node",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  }
}
