# OpenID Connect configuration (Zitadel)
OIDC_ISSUER=https://your-instance.zitadel.cloud
VITE_OIDC_ISSUER=https://your-instance.zitadel.cloud
OIDC_CLIENT_ID=000000000000000000
VITE_OIDC_CLIENT_ID=000000000000000000

# Set these to a valid Zitadel user to run the OIDC e2e test.
#ZITADEL_TEST_EMAIL=test@example.com
#ZITADEL_TEST_PASSWORD=.....................

# OIDC subject (the 'sub' claim, == Zitadel user ID) of the account to
# auto-promote to admin tier. The Hono server reads this at startup and on
# every OIDC sign-in. Leave unset if you don't want auto-promotion.
#ADMIN_USER_ID=000000000000000000
